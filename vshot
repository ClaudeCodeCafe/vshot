#!/bin/bash
set -eo pipefail

# ── vshot — Video frame extraction for AI consumption ──────────────────────
# Extract frames from video and optionally create a montage grid image.
# Designed to let AI assistants "watch" videos via image analysis.

VERSION="0.1.0"
SCRIPT_NAME="vshot"

# Unique prefix per run to avoid stale frame collisions (#1)
RUN_ID=$$

# ── Defaults ───────────────────────────────────────────────────────────────
MODE="overview"
FRAMES=20
INTERVAL=""
MONTAGE=false
OUTPUT_DIR=""
TIMESTAMPS=true
CLEANUP=false

# ── Usage ──────────────────────────────────────────────────────────────────
usage() {
  cat <<EOF
${SCRIPT_NAME} v${VERSION} — Video frame extraction for AI consumption

USAGE:
  ${SCRIPT_NAME} <video> [options]

OPTIONS:
  --frames N        Number of frames to extract (default: 20)
                    Note: capped to video duration in seconds for even spacing.
  --interval N      Extract every N seconds (overrides --frames)
  --mode MODE       overview | text | detail (default: overview)
  --montage         Combine all frames into a single grid image
  --output DIR      Output directory (default: <video>_vshot/)
  --no-timestamps   Don't burn timestamps into extracted frames
  --cleanup         Remove individual frames after creating montage
  -h, --help        Show this help

MODES:
  overview   480x270   Low-res color. Quick overview of video flow.
  text       960x540   Mid-res. Optimized for reading text/UI content.
  detail     1280x720  High-res. Full detail for design review.

EXAMPLES:
  ${SCRIPT_NAME} video.mp4                          # 20 frames, overview
  ${SCRIPT_NAME} video.mp4 --montage                # single grid image
  ${SCRIPT_NAME} video.mp4 --mode text --montage    # text-readable grid
  ${SCRIPT_NAME} video.mp4 --interval 5 --montage   # every 5s, grid
  ${SCRIPT_NAME} video.mp4 --frames 30 --mode detail # 30 high-res frames
EOF
  exit 0
}

# ── Mode resolution lookup ─────────────────────────────────────────────────
get_mode_settings() {
  case "$MODE" in
    overview) W=480;  H=270; Q=70 ;;
    text)     W=960;  H=540; Q=85 ;;
    detail)   W=1280; H=720; Q=90 ;;
    *) echo "Error: unknown mode '$MODE'. Use: overview, text, detail" >&2; exit 1 ;;
  esac
}

# ── Dependency check (#8, #14) ─────────────────────────────────────────────
check_deps() {
  if ! command -v ffmpeg &>/dev/null; then
    echo "Error: ffmpeg is required. Install with your package manager, e.g. brew install ffmpeg" >&2
    exit 1
  fi
  if ! command -v ffprobe &>/dev/null; then
    echo "Error: ffprobe is required (comes with ffmpeg). Install with your package manager, e.g. brew install ffmpeg" >&2
    exit 1
  fi
  if $MONTAGE && ! command -v montage &>/dev/null; then
    echo "Error: ImageMagick is required for --montage. Install with your package manager, e.g. brew install imagemagick" >&2
    exit 1
  fi
}

# ── Validation helpers (#2) ────────────────────────────────────────────────
is_positive_integer() {
  case "$1" in
    ''|*[!0-9]*) return 1 ;;
    0) return 1 ;;
    *) return 0 ;;
  esac
}

# ── Parse args (#7: check $# before accessing $2) ─────────────────────────
VIDEO=""
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help) usage ;;
    --frames)
      if [ $# -lt 2 ]; then
        echo "Error: --frames requires a value" >&2; exit 1
      fi
      FRAMES="$2"; shift 2 ;;
    --interval)
      if [ $# -lt 2 ]; then
        echo "Error: --interval requires a value" >&2; exit 1
      fi
      INTERVAL="$2"; shift 2 ;;
    --mode)
      if [ $# -lt 2 ]; then
        echo "Error: --mode requires a value" >&2; exit 1
      fi
      MODE="$2"; shift 2 ;;
    --montage) MONTAGE=true; shift ;;
    --output)
      if [ $# -lt 2 ]; then
        echo "Error: --output requires a value" >&2; exit 1
      fi
      OUTPUT_DIR="$2"; shift 2 ;;
    --no-timestamps) TIMESTAMPS=false; shift ;;
    --cleanup) CLEANUP=true; shift ;;
    -*) echo "Unknown option: $1" >&2; exit 1 ;;
    *)
      if [ -z "$VIDEO" ]; then
        VIDEO="$1"
      else
        echo "Error: multiple video files not supported" >&2; exit 1
      fi
      shift ;;
  esac
done

# ── Input validation (#2) ─────────────────────────────────────────────────
if [ -z "$VIDEO" ]; then
  echo "Error: no video file specified" >&2
  echo "Usage: ${SCRIPT_NAME} <video> [options]" >&2
  exit 1
fi

if [ ! -f "$VIDEO" ]; then
  echo "Error: file not found: $VIDEO" >&2
  exit 1
fi

if ! is_positive_integer "$FRAMES"; then
  echo "Error: --frames must be a positive integer, got '$FRAMES'" >&2
  exit 1
fi

if [ -n "$INTERVAL" ]; then
  if ! is_positive_integer "$INTERVAL"; then
    echo "Error: --interval must be a positive integer, got '$INTERVAL'" >&2
    exit 1
  fi
fi

get_mode_settings
check_deps

# ── Temp file for capturing stderr (#3) ───────────────────────────────────
STDERR_TMP=$(mktemp "${TMPDIR:-/tmp}/vshot_stderr.XXXXXX")
cleanup_tmp() {
  rm -f -- "$STDERR_TMP"
}
trap cleanup_tmp EXIT

# ── Get video info (#3: capture stderr, check exit codes) ─────────────────
if ! DURATION=$(ffprobe -v error -show_entries format=duration -of csv=p=0 -- "$VIDEO" 2>"$STDERR_TMP") || [ -z "$DURATION" ]; then
  echo "Error: could not determine video duration" >&2
  if [ -s "$STDERR_TMP" ]; then
    echo "  ffprobe: $(cat "$STDERR_TMP")" >&2
  fi
  exit 1
fi
DURATION=$(echo "$DURATION" | head -1)

# Handle sub-second durations gracefully (#9)
# Use awk instead of bc for portability (#8)
DURATION_INT=$(echo "$DURATION" | awk '{d = int($1); if (d < 1 && $1 > 0) d = 1; print d}')

if [ -z "$DURATION_INT" ] || [ "$DURATION_INT" -eq 0 ] 2>/dev/null; then
  echo "Error: could not determine video duration (got: $DURATION)" >&2
  exit 1
fi

# Detect original video dimensions (#3, #9, #10: -- before path)
V_WIDTH=$(ffprobe -v error -select_streams v:0 -show_entries stream=width -of csv=p=0 -- "$VIDEO" 2>"$STDERR_TMP" | head -1 | tr -d ',[:space:]')
V_HEIGHT=$(ffprobe -v error -select_streams v:0 -show_entries stream=height -of csv=p=0 -- "$VIDEO" 2>"$STDERR_TMP" | head -1 | tr -d ',[:space:]')

# Validate dimensions (#9)
if [ -z "$V_WIDTH" ] || [ -z "$V_HEIGHT" ]; then
  echo "Error: could not determine video dimensions" >&2
  if [ -s "$STDERR_TMP" ]; then
    echo "  ffprobe: $(cat "$STDERR_TMP")" >&2
  fi
  exit 1
fi
if ! is_positive_integer "$V_WIDTH" || ! is_positive_integer "$V_HEIGHT"; then
  echo "Error: could not determine valid video dimensions (${V_WIDTH}x${V_HEIGHT})" >&2
  exit 1
fi

# Adjust output dimensions to match source aspect ratio (#8: awk instead of bc)
if [ -n "$V_WIDTH" ] && [ -n "$V_HEIGHT" ] && [ "$V_WIDTH" -gt 0 ]; then
  if [ "$V_HEIGHT" -gt "$V_WIDTH" ]; then
    # Portrait (9:16 etc) — fix height to mode height, scale width proportionally
    H_OUT=$H
    W_OUT=$(echo "$H_OUT $V_WIDTH $V_HEIGHT" | awk '{printf "%d", $1 * $2 / $3}')
    # Ensure even number (ffmpeg requires it)
    W_OUT=$(( (W_OUT / 2) * 2 ))
    ORIENTATION="portrait"
  else
    # Landscape (16:9 etc) — fix width to mode width, scale height proportionally
    W_OUT=$W
    H_OUT=$(echo "$W_OUT $V_HEIGHT $V_WIDTH" | awk '{printf "%d", $1 * $2 / $3}')
    H_OUT=$(( (H_OUT / 2) * 2 ))
    ORIENTATION="landscape"
  fi
  # Clamp to minimum 2 for extreme aspect ratios
  [ "$W_OUT" -lt 2 ] && W_OUT=2
  [ "$H_OUT" -lt 2 ] && H_OUT=2
else
  W_OUT=$W
  H_OUT=$H
  ORIENTATION="landscape"
fi

# ── Calculate frame extraction rate ────────────────────────────────────────
if [ -n "$INTERVAL" ]; then
  FPS_FILTER="fps=1/${INTERVAL}"
  # Estimate frame count for display
  FRAMES=$(echo "$DURATION_INT $INTERVAL" | awk '{d=int($1/$2); if(d<1) d=1; print d}')
else
  # (#12) Warn if FRAMES was capped
  if [ $FRAMES -gt $DURATION_INT ]; then
    echo "Warning: --frames $FRAMES exceeds video duration (${DURATION_INT}s). Capping to $DURATION_INT." >&2
    FRAMES=$DURATION_INT
  fi
  FPS=$(echo "$FRAMES $DURATION" | awk '{printf "%.6f", $1 / $2}')
  FPS_FILTER="fps=${FPS}"
fi

# ── Setup output (#10: -- before path operands) ───────────────────────────
BASENAME=$(basename "$VIDEO" | sed 's/\.[^.]*$//')
if [ -z "$OUTPUT_DIR" ]; then
  OUTPUT_DIR="$(dirname "$VIDEO")/${BASENAME}_vshot"
fi
mkdir -p -- "$OUTPUT_DIR"

# Frame filename prefix for this run (#1)
FRAME_PREFIX="vshot_${RUN_ID}_frame"

# ── Extract frames (#1, #3, #8, #10) ──────────────────────────────────────
echo "📹 ${SCRIPT_NAME} v${VERSION}"
echo "   Video:    $(basename "$VIDEO") (${DURATION_INT}s, ${V_WIDTH}x${V_HEIGHT} ${ORIENTATION})"
echo "   Mode:     $MODE (${W_OUT}x${H_OUT})"
echo "   Frames:   $FRAMES"
echo "   Output:   $OUTPUT_DIR/"
echo ""

echo -n "   Extracting frames..."

# (#3) Capture stderr, check exit code
if ! ffmpeg -v error -i "$VIDEO" \
  -vf "${FPS_FILTER},scale=${W_OUT}:${H_OUT}" \
  -q:v $(( (100 - Q) * 31 / 100 + 1 )) \
  "${OUTPUT_DIR}/${FRAME_PREFIX}_%04d.jpg" \
  2>"$STDERR_TMP"; then
  echo " FAILED" >&2
  echo "Error: ffmpeg frame extraction failed" >&2
  if [ -s "$STDERR_TMP" ]; then
    echo "  ffmpeg: $(cat "$STDERR_TMP")" >&2
  fi
  exit 1
fi

# (#4) Use find for frame counting (bash 3 compatible)
EXTRACTED=$(find "$OUTPUT_DIR" -name "${FRAME_PREFIX}_*.jpg" -type f 2>/dev/null | wc -l | tr -d ' ')
echo " done (${EXTRACTED} frames)"

if [ "$EXTRACTED" -eq 0 ]; then
  echo "Error: no frames were extracted" >&2
  exit 1
fi

# ── Burn timestamps (#15: count and warn on failures) ─────────────────────
if $TIMESTAMPS && [ "$EXTRACTED" -gt 0 ]; then
  echo -n "   Adding timestamps..."
  # Use awk instead of bc (#8)
  STEP=$(echo "$DURATION $EXTRACTED" | awk '{printf "%.2f", $1 / $2}')
  i=0
  TS_FAILURES=0
  for frame in "${OUTPUT_DIR}"/${FRAME_PREFIX}_*.jpg; do
    SECS=$(echo "$i $STEP" | awk '{printf "%d", $1 * $2}')
    MINS=$((SECS / 60))
    REMAINING=$((SECS % 60))
    TS=$(printf "%d:%02d" "$MINS" "$REMAINING")

    if ffmpeg -v error -y -i "$frame" \
      -vf "drawtext=text='${TS}':x=8:y=h-24:fontsize=16:fontcolor=white:borderw=2:bordercolor=black" \
      "${frame}.tmp.jpg" 2>"$STDERR_TMP" && [ -f "${frame}.tmp.jpg" ]; then
      mv -- "${frame}.tmp.jpg" "$frame"
    else
      TS_FAILURES=$((TS_FAILURES + 1))
      rm -f -- "${frame}.tmp.jpg"
    fi

    i=$((i + 1))
  done
  if [ "$TS_FAILURES" -gt 0 ]; then
    echo " done (${TS_FAILURES} timestamp burn-in(s) failed)"
  else
    echo " done"
  fi
fi

# ── Create montage (#5: proper error handling) ────────────────────────────
if $MONTAGE && [ "$EXTRACTED" -gt 0 ]; then
  echo -n "   Creating montage..."

  # Calculate grid: aim for a reasonable final image aspect ratio (#8: awk instead of bc)
  if [ "$ORIENTATION" = "portrait" ]; then
    # Portrait frames: more columns to fill horizontal space
    COLS=$(echo "$EXTRACTED" | awk '{printf "%d", sqrt($1 * 2)}')
  else
    # Landscape frames: standard 16:9-ish grid
    COLS=$(echo "$EXTRACTED" | awk '{printf "%d", sqrt($1 * 16 / 9)}')
  fi
  [ "$COLS" -lt 2 ] && COLS=2
  ROWS=$(( (EXTRACTED + COLS - 1) / COLS ))

  TILE="${COLS}x${ROWS}"
  MONTAGE_FILE="${OUTPUT_DIR}/${BASENAME}_montage_${RUN_ID}.jpg"

  # (#5) Run montage directly, check exit code, verify output
  if ! montage "${OUTPUT_DIR}"/${FRAME_PREFIX}_*.jpg \
    -tile "$TILE" \
    -geometry "${W_OUT}x${H_OUT}+4+4" \
    -background '#0e0e1a' \
    -quality "$Q" \
    "$MONTAGE_FILE" 2>"$STDERR_TMP"; then
    echo " FAILED" >&2
    echo "Error: montage creation failed" >&2
    if [ -s "$STDERR_TMP" ]; then
      echo "  montage: $(cat "$STDERR_TMP")" >&2
    fi
    exit 1
  fi

  # Verify output file exists and is non-empty (#5)
  if [ ! -s "$MONTAGE_FILE" ]; then
    echo " FAILED" >&2
    echo "Error: montage file was not created or is empty" >&2
    exit 1
  fi

  MONTAGE_SIZE=$(du -h -- "$MONTAGE_FILE" | cut -f1 | tr -d ' ')
  echo " done"
  echo ""
  echo "   📊 Montage: ${BASENAME}_montage_${RUN_ID}.jpg (${TILE} grid, ${MONTAGE_SIZE})"

  # (#6) Only delete this run's prefixed frames
  if $CLEANUP; then
    rm -f -- "${OUTPUT_DIR}"/${FRAME_PREFIX}_*.jpg
    echo "   🧹 Individual frames removed"
  fi
else
  echo ""
fi

# ── Summary ────────────────────────────────────────────────────────────────
TOTAL_SIZE=$(du -sh -- "$OUTPUT_DIR" | cut -f1 | tr -d ' ')
echo "   📁 Total: ${TOTAL_SIZE} → ${OUTPUT_DIR}/"

if $MONTAGE; then
  MONTAGE_PATH="$(cd -- "$OUTPUT_DIR" && pwd)/${BASENAME}_montage_${RUN_ID}.jpg"
  echo ""
  echo "   💡 AI に読ませる:"
  echo "   Read(\"${MONTAGE_PATH}\")"
fi
